{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "plugin": [
    "@tarquinen/opencode-dcp@latest",
    "superpowers@git+https://github.com/obra/superpowers.git",
    "rtk"
  ],
  "permission": {
    "bash": {
      "*": "allow",
      /* Block sensitive files first */
      "cat *.env*": "ask",
      "cat *.key": "ask",
      "cat *.pem": "ask",
      "cat *.tfstate*": "ask",
      "cat *credentials*": "ask",
      "cat *history": "ask",
      "cat *kubeconfig*": "ask",
      "cat *token*": "ask",
      "cat.env*": "ask",
      "cat.ssh/*": "ask",
      "docker exec *": "ask",
      "docker run *-it*": "ask",
      "docker run *bash*": "ask",
      "docker run *sh*": "ask",
      "env": "ask",
      "grep *.aws/*": "ask",
      "kubectl delete*": "ask",
      "kubectl describe secret*": "ask",
      "printenv": "ask",
      "rg *.aws/*": "ask",
      "rm -rf *": "ask",
      "terraform apply*": "ask",
      "terraform destroy*": "ask",
      "tofu apply*": "ask",
      "tofu destroy*": "ask"
    },
    "edit": "allow",
  },
  "watcher": {
    "ignore": [
      "**/node_modules/**",
      "**/dist/**",
      "**/.git/**",
      "**/out/**",
      "**/build/**",
      "**/coverage/**",
      "**/.cache/**",
      "**/**/*.log",
      "**/.venv/**",
      "**/__pycache__/**",
      "**/.DS_Store",
      "**/*.tfstate",
      "**/*.sqlite3"
    ]
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 15000
  },
  "instructions": [
    ".cursor/rules/*.md",
    "AGENTS.md",
    "CONTRIBUTING.md"
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?exaApiKey={env:EXA_API_KEY}",
      "enabled": true
    },
    "github": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_TOKEN}"
      },
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    }
  }
}
