{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "plugin": [
    "@tarquinen/opencode-dcp@latest",
    "rtk"
  ],
  "permission": {
    "bash": {
      "*": "ask",
      /* Block sensitive files first */
      "cat *.env": "ask",
      "cat *.key": "ask",
      "cat *.pem": "ask",
      "cat *credentials*": "ask",
      "cat *history": "ask",
      "cat *token*": "ask",
      "cat .ssh/*": "ask",
      "cat *.tfstate*": "ask",
      "cat *kubeconfig*": "ask",
      "env": "ask",
      "grep * .aws/*": "ask",
      "kubectl describe secret*": "ask",
      "ls -a": "ask",
      "printenv": "ask",
      "rg * .aws/*": "ask",
      "docker exec *": "ask",
      "docker run *sh*": "ask",
      "docker run *bash*": "ask",
      "docker run *-it*": "ask",
      /* Then allow general usage */
      "aws * describe-*": "allow",
      "aws * get-*": "allow",
      "aws * list-*": "allow",
      "cat *": "allow",
      "date": "allow",
      "docker images *": "allow",
      "docker logs *": "allow",
      "docker ps *": "allow",
      "du -sh *": "allow",
      "find *": "allow",
      "git branch *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git status *": "allow",
      "go test *": "allow",
      "go vet *": "allow",
      "golangci-lint *": "allow",
      "grep *": "allow",
      "grep -r *": "allow",
      "head *": "allow",
      "jq *": "allow",
      "kubectl config get-contexts": "allow",
      "kubectl describe *": "allow",
      "kubectl get *": "allow",
      "kubectl top *": "allow",
      "ls *": "allow",
      "mypy *": "allow",
      "ng *": "allow",
      "npm install *": "allow",
      "npm run build *": "allow",
      "npm run lint *": "allow",
      "npm test *": "allow",
      "pwd": "allow",
      "pytest *": "allow",
      "rg *": "allow",
      "rtk cc-economics *": "allow",
      "rtk config *": "allow",
      "rtk deps *": "allow",
      "rtk diff *": "allow",
      "rtk discover *": "allow",
      "rtk env *": "allow",
      "rtk err *": "allow",
      "rtk find *": "allow",
      "rtk format *": "allow",
      "rtk gain *": "allow",
      "rtk golangci-lint *": "allow",
      "rtk grep *": "allow",
      "rtk hook *": "allow",
      "rtk hook-audit *": "allow",
      "rtk json *": "allow",
      "rtk learn *": "allow",
      "rtk lint *": "allow",
      "rtk log *": "allow",
      "rtk ls *": "allow",
      "rtk mypy *": "allow",
      "rtk prettier *": "allow",
      "rtk read *": "allow",
      "rtk rewrite *": "allow",
      "rtk rubocop *": "allow",
      "rtk session *": "allow",
      "rtk smart *": "allow",
      "rtk summary *": "allow",
      "rtk telemetry *": "allow",
      "rtk tree *": "allow",
      "rtk tsc *": "allow",
      "rtk verify *": "allow",
      "rtk wc *": "allow",
      "ruff *": "allow",
      "stat *": "allow",
      "tail *": "allow",
      "terraform plan *": "allow",
      "terraform show *": "allow",
      "terraform state list *": "allow",
      "tofu plan *": "allow",
      "tofu show *": "allow",
      "tofu state list *": "allow",
      "wc *": "allow",
      "whoami": "allow"
    },
    "edit": "allow",
    "webfetch": "allow",
    "external_directory": "ask",
    "doom_loop": "ask",
    "distill": "allow"
  },
  "watcher": {
    "ignore": [
      "**/node_modules/**",
      "**/dist/**",
      "**/.git/**",
      "**/out/**",
      "**/build/**",
      "**/coverage/**",
      "**/.cache/**",
      "**/**/*.log",
      "**/.venv/**",
      "**/__pycache__/**",
      "**/.DS_Store",
      "**/*.tfstate",
      "**/*.sqlite3"
    ]
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 15000
  },
  "instructions": [
    ".cursor/rules/*.md",
    "AGENTS.md",
    "CONTRIBUTING.md"
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?exaApiKey={env:EXA_API_KEY}",
      "enabled": true
    },
    "github": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_TOKEN}"
      },
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    }
  }
}
