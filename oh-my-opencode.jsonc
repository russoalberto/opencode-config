{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "nano-gpt/moonshotai/kimi-k2.5-thinking"
    },
    "hephaestus": {
      "model": "nano-gpt/qwen/qwen3-coder"
    },
    "oracle": {
      "model": "nano-gpt/zai-org/glm-5:thinking"
    },
    "librarian": {
      "model": "nano-gpt/moonshotai/kimi-k2.5"
    },
    "explore": {
      "model": "nano-gpt/minimax/minimax-m2.5"
    },
    "metis": {
      "model": "nano-gpt/qwen/qwen3.5-plus-thinking"
    },
    "momus": {
      "model": "nano-gpt/zai-org/glm-5-original:thinking"
    },
    "prometheus": {
      "model": "nano-gpt/zai-org/glm-4.7:thinking"
    },
    "atlas": {
      "model": "nano-gpt/meta-llama/llama-3.3-70b-instruct"
    }
  },
  "categories": {
    "ultrabrain": {
      "model": "nano-gpt/qwen/qwen3.5-397b-a17b-thinking"
    },
    "deep": {
      "model": "nano-gpt/moonshotai/kimi-k2.5-thinking"
    },
    "visual-engineering": {
      "model": "nano-gpt/qwen/qwen3.5-plus"
    },
    "quick": {
      "model": "nano-gpt/minimax/minimax-m2.5"
    }
  }
}
